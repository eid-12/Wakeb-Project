# Copy to `.env` or `.env.local` for local builds. Vue CLI only exposes vars prefixed with VUE_APP_.

# --- Backend (browser → same origin Express proxy OR vue-cli dev proxy) ---
VUE_APP_API_GATEWAY_URL=/api
VUE_APP_AUTH_API_URL=/api/auth

# --- Mapbox ---
# VUE_APP_MAPBOX_ACCESS_TOKEN=pk.your_token
VUE_APP_API_KEY=
VUE_APP_MAPBOX_API=https://api.mapbox.com/geocoding/v5/mapbox.places

# --- `npm run serve` dev server (vue.config.js) ---
# Port 5174 avoids clashing with Spring gateway on 8080.
# VUE_DEV_PORT=5174
# Direct to microservices (default). Auth must listen on 8081 if gateway uses 8080.
# VUE_DEV_AUTH_ORIGIN=http://localhost:8081
# VUE_DEV_GATEWAY_ORIGIN=http://localhost:8080
# To proxy via Express instead: run `npm run dev:proxy` in another terminal, then:
# VUE_DEV_USE_EXPRESS=1

# --- `node server.js` / production (not VUE_APP_) ---
# AUTH_SERVICE_ORIGIN=http://localhost:8081
# API_GATEWAY_ORIGIN=http://localhost:8080
# PORT=3000
# NODE_ENV=production
